<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Base Page Style -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonBackground}" />
    </Style>

    <!-- Tactical HUD Glassmorphism Panel Styles -->
    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassBackground}" />
        <Setter Property="Stroke" Value="{StaticResource CrimsonGlassBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="22" />
        </Setter>
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource CrimsonShadowRed}"
                    Offset="0,0"
                    Radius="26"
                    Opacity="0.32" />
        </Setter>
    </Style>

    <Style x:Key="HudPanel" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="Padding" Value="14" />
        <Setter Property="StrokeThickness" Value="1.4" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="18" />
        </Setter>
    </Style>

    <Style x:Key="NeonFrame" TargetType="Border" BasedOn="{StaticResource GlassPanel}">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="Stroke" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource CrimsonPrimaryAccent}"
                    Offset="0,0"
                    Radius="34"
                    Opacity="0.56" />
        </Setter>
    </Style>

    <Style x:Key="InsetGlassPanel" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="Stroke" Value="{StaticResource CrimsonGlassBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="14" />
        </Setter>
    </Style>

    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="Stroke" Value="{StaticResource CrimsonGlassBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="18" />
        </Setter>
    </Style>

    <!-- Crimson Nexus Button Styles -->
    <Style x:Key="CyberButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource CrimsonPrimaryAccent}"
                    Offset="0,0"
                    Radius="18"
                    Opacity="0.58" />
        </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource CrimsonGlassBorder}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <Style x:Key="CompactGhostButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Tactical Typography -->
    <Style x:Key="CyberLabelHeader" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CyberLabelTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="0.8" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="CyberLabelSection" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.6" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="CyberLabelBody" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="CyberLabelMuted" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextSecondary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="HudMetricLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextSecondary}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="1.4" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <Style x:Key="HudMetricValue" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <!-- Entry Style for Settings -->
    <Style x:Key="CyberEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource CrimsonTextSecondary}" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="CyberEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource CrimsonTextSecondary}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- Picker Style for Settings -->
    <Style x:Key="CyberPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource CrimsonGlassInset}" />
        <Setter Property="TextColor" Value="{StaticResource CrimsonTextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource CrimsonTextSecondary}" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="CyberSlider" TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource CrimsonSurfaceElevated}" />
        <Setter Property="ThumbColor" Value="{StaticResource CrimsonPrimaryAccent}" />
    </Style>

    <Style x:Key="StageModeButton" TargetType="Button">
        <Setter Property="BorderColor" Value="{StaticResource CrimsonGlassBorder}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HeightRequest" Value="38" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Switch Style -->
    <Style x:Key="CyberSwitch" TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource CrimsonPrimaryAccent}" />
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

</ResourceDictionary>
