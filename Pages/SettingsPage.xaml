<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:QuantumZ.UI.ViewModels"
             xmlns:settings="clr-namespace:QuantumZ.Core.Models.Settings"
             x:Class="QuantumZ.UI.Pages.SettingsPage"
             NavigationPage.HasNavigationBar="False"
             Title="System Configuration">

    <Grid BackgroundColor="{StaticResource CrimsonBackground}"
          RowDefinitions="*,Auto">

        <BoxView Grid.RowSpan="2"
                 HeightRequest="320"
                 Opacity="0.32"
                 VerticalOptions="Start">
            <BoxView.Background>
                <RadialGradientBrush Center="0.2,0.0" Radius="0.95">
                    <GradientStop Color="{StaticResource CrimsonNeonDim}" Offset="0.0" />
                    <GradientStop Color="{StaticResource CrimsonBackground}" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Grid Grid.RowSpan="2"
              InputTransparent="True"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="38"
              Opacity="0.32">
            <BoxView Grid.Row="0" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="2" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="3" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="4" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="5" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
        </Grid>

        <ScrollView Grid.Row="0"
                    Padding="20,20,20,8">
            <VerticalStackLayout Spacing="18">
                <VerticalStackLayout Spacing="4">
                    <Label Text="SYSTEM CONFIGURATION"
                           Style="{StaticResource CyberLabelHeader}"
                           FontSize="26"
                           HorizontalOptions="Start" />
                    <Label Text="CRIMSON NEXUS // PROVIDER ROUTING, VOICE, LOGGING, AND MCP FABRIC"
                           Style="{StaticResource CyberLabelMuted}"
                           FontSize="13"
                           CharacterSpacing="1.1"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <!-- Status Message -->
                <Border IsVisible="{Binding Source={RelativeSource Self}, Path=BindingContext.StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                        Style="{StaticResource GlassPanel}"
                        BackgroundColor="{StaticResource CyberRedSoft}"
                        Padding="12">
                    <Label Text="{Binding StatusMessage}"
                           TextColor="{StaticResource CyberWhiteText}"
                           FontSize="13"
                           HorizontalOptions="Center" />
                </Border>

                <!-- Backend Configuration Hierarchy -->
                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="BACKEND CONFIGURATION"
                               Style="{StaticResource CyberLabelSection}" />

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                        Text="Use Local LLM (llama.cpp)"
                                        Style="{StaticResource CyberLabelBody}"
                                        FontSize="13"
                                        VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding UseLocalLlm}"
                                        Style="{StaticResource CyberSwitch}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                        Text="Use Local TTS (Android/On-Device)"
                                        Style="{StaticResource CyberLabelBody}"
                                        FontSize="13"
                                        VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding UseLocalTts}"
                                        Style="{StaticResource CyberSwitch}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                        Text="Expose advanced network controls"
                                        Style="{StaticResource CyberLabelBody}"
                                        FontSize="13"
                                        VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding ShowAdvancedNetworkSettings}"
                                        Style="{StaticResource CyberSwitch}" />
                            </Grid>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding ShowAdvancedNetworkSettings}">
                            <Label Text="Active Service Pipeline"
                                    Style="{StaticResource CyberLabelBody}"
                                    FontSize="13" />
                            <Picker ItemsSource="{Binding Services}"
                                    SelectedItem="{Binding SelectedService}"
                                    Title="Select service to configure"
                                    Style="{StaticResource CyberPicker}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding ShowAdvancedNetworkSettings}">
                            <Label Text="Provider Routing"
                                    Style="{StaticResource CyberLabelBody}"
                                    FontSize="13" />
                            <Picker ItemsSource="{Binding CurrentProviders}"
                                    SelectedItem="{Binding SelectedProviderName}"
                                    Title="Select provider for this service"
                                    Style="{StaticResource CyberPicker}" />
                        </VerticalStackLayout>

                        <Border Style="{StaticResource InsetGlassPanel}" Padding="12"
                                IsVisible="{Binding ShowAdvancedNetworkSettings}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="PROVIDER PARAMETERS"
                                        Style="{StaticResource CyberLabelMuted}"
                                        FontSize="11"
                                        FontAttributes="Bold" />

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Endpoint URL"
                                            Style="{StaticResource CyberLabelBody}"
                                            FontSize="12" />
                                    <Entry Text="{Binding EditingUrl}"
                                           Placeholder="http://..."
                                           Style="{StaticResource CyberEntry}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Model Identifier"
                                            Style="{StaticResource CyberLabelBody}"
                                            FontSize="12" />
                                    <Entry Text="{Binding EditingModelId}"
                                           Placeholder="model-id..."
                                           Style="{StaticResource CyberEntry}" />
                                </VerticalStackLayout>

                                <Button Text="Refresh Models (LLM)"
                                        Command="{Binding RefreshModelsCommand}"
                                        IsVisible="{Binding SelectedService, Converter={StaticResource StringEqualsConverter}, ConverterParameter='LLM'}"
                                        Style="{StaticResource GhostButton}" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                             <Label Grid.Column="0"
                                    Text="Dynamic routing active based on selected provider."
                                    Style="{StaticResource CyberLabelMuted}"
                                    FontSize="11" />
                             <ActivityIndicator Grid.Column="1"
                                                IsRunning="{Binding IsDiscoveringModels}"
                                                IsVisible="{Binding IsDiscoveringModels}"
                                                Color="{StaticResource CyberRedNeon}"
                                                WidthRequest="24"
                                                HeightRequest="24" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Assistant Core Settings -->
                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Assistant Core"
                                Style="{StaticResource CyberLabelSection}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Custom System Message"
                                    Style="{StaticResource CyberLabelBody}"
                                    FontSize="13" />
                            <Entry Text="{Binding CustomSystemMessage}"
                                    Placeholder="You are a tactical aerospace assistant..."
                                    Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Pre-roll Buffer (seconds)"
                                    Style="{StaticResource CyberLabelBody}"
                                    FontSize="13" />
                            <Entry Text="{Binding PreRollSeconds}"
                                    Keyboard="Numeric"
                                    Placeholder="1.0"
                                    Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Voice Control -->
                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Voice Control"
                                Style="{StaticResource CyberLabelSection}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Wake Word"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding WakeWordText}"
                                   Placeholder="hey quantum"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Audio Routing"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Picker ItemsSource="{Binding AudioRoutingOptions}"
                                    SelectedItem="{Binding SelectedAudioRouting}"
                                    Style="{StaticResource CyberPicker}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Voice Input Mode"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Picker ItemsSource="{Binding VoiceInputModeOptions}"
                                    SelectedItem="{Binding SelectedVoiceInputMode}"
                                    Style="{StaticResource CyberPicker}" />
                            <Label Text="{Binding VoiceInputModeDescription}"
                                   Style="{StaticResource CyberLabelMuted}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding UseOnDeviceStt, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Whisper Model Path"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding WhisperModelPath}"
                                   Placeholder="/sdcard/whisper/base.bin"
                                   Style="{StaticResource CyberEntry}" />
                            <ProgressBar Progress="{Binding WhisperDownloadProgress}"
                                         ProgressColor="{StaticResource CyberRedNeon}"
                                         IsVisible="{Binding IsWhisperDownloading}"
                                         HeightRequest="4" />
                            <Button Text="Download Whisper Model"
                                    Command="{Binding DownloadWhisperCommand}"
                                    IsEnabled="{Binding IsWhisperDownloading, Converter={StaticResource InvertedBoolConverter}}"
                                    Style="{StaticResource GhostButton}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Activity Logging -->
                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Activity Logging"
                               Style="{StaticResource CyberLabelSection}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="Enable Activity Logging"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding EnableActivityLogging}"
                                    Style="{StaticResource CyberSwitch}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="Enable Activity Analysis"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding EnableActivityAnalysis}"
                                    Style="{StaticResource CyberSwitch}" />
                        </Grid>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Logging Interval (minutes)"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding LoggingIntervalMinutes}"
                                   Keyboard="Numeric"
                                   Placeholder="15"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Summarization Triggers"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding SummarizationTriggers}"
                                   Placeholder="meeting, call, task"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Obsidian Vault Path"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding ObsidianVaultPath}"
                                   Placeholder="/sdcard/obsidian/quantumz"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Obsidian MCP Vault Path"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding ObsidianMcpPath}"
                                   Placeholder="C:/Users/yelle/.obsidian-vault"
                                   Style="{StaticResource CyberEntry}" />
                            <Button Text="Add Obsidian MCP Server"
                                    Command="{Binding AddObsidianMcpCommand}"
                                    Style="{StaticResource GhostButton}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- MCP Servers -->
                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="MCP Servers"
                               Style="{StaticResource CyberLabelSection}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Name"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding McpNameInput}"
                                   Placeholder="obsidian-server"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Endpoint"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding McpEndpointInput}"
                                   Placeholder="http://192.168.1.10:3000/sse"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="API Key (optional)"
                                   Style="{StaticResource CyberLabelBody}"
                                   FontSize="13" />
                            <Entry Text="{Binding McpApiKeyInput}"
                                   Placeholder="sk-..."
                                   IsPassword="True"
                                   Style="{StaticResource CyberEntry}" />
                        </VerticalStackLayout>

                        <Button Text="Add MCP Server"
                                Command="{Binding AddMcpServerCommand}"
                                Style="{StaticResource GhostButton}" />

                        <Label Text="Configured Servers"
                               Style="{StaticResource CyberLabelBody}"
                               FontSize="13" />

                        <CollectionView ItemsSource="{Binding McpServers}"
                                        HeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource InsetGlassPanel}"
                                            Padding="10"
                                            Margin="0,4">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <VerticalStackLayout Grid.Column="0"
                                                                 Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       TextColor="{StaticResource CyberWhiteText}"
                                                       FontSize="13"
                                                       FontAttributes="Bold" />
                                                <Label Text="{Binding Endpoint}"
                                                       TextColor="{StaticResource CyberTextMuted}"
                                                       FontSize="11"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Transport}"
                                                       TextColor="{StaticResource CyberRedNeon}"
                                                       FontSize="10" />
                                            </VerticalStackLayout>
                                            <Button Grid.Column="1"
                                                    Text="Remove"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SettingsViewModel}}, Path=RemoveMcpServerCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Style="{StaticResource CompactGhostButton}"
                                                    VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="84" Opacity="0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Anchored Save Action -->
        <Border Grid.Row="1"
                Padding="18,14,18,20"
                BackgroundColor="{StaticResource CrimsonSurfaceElevated}"
                Stroke="{StaticResource CrimsonGlassBorder}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>
            <Button Text="Save Configuration"
                    Command="{Binding SaveSettingsCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource CyberButton}" />
        </Border>
    </Grid>
</ContentPage>
