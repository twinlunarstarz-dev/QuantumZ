<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuantumZ.UI.Pages.MainAssistantPage"
             NavigationPage.HasNavigationBar="False"
             Title="Crimson Nexus">

    <Grid BackgroundColor="{StaticResource CrimsonBackground}"
          RowDefinitions="*,Auto">

        <BoxView Grid.RowSpan="2"
                 BackgroundColor="{StaticResource CrimsonBackground}" />

        <BoxView Grid.RowSpan="2"
                 HeightRequest="340"
                 Opacity="0.34"
                 VerticalOptions="Start">
            <BoxView.Background>
                <RadialGradientBrush Center="0.5,0.0" Radius="0.9">
                    <GradientStop Color="{StaticResource CrimsonNeonDim}" Offset="0.0" />
                    <GradientStop Color="{StaticResource CrimsonBackground}" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Grid Grid.RowSpan="2"
              InputTransparent="True"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="44"
              Opacity="0.28">
            <BoxView Grid.Row="0" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="2" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="3" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="4" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="5" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
            <BoxView Grid.Row="6" HeightRequest="1" BackgroundColor="{StaticResource CrimsonScanline}" />
        </Grid>

        <Grid Grid.Row="0">
            <VerticalStackLayout x:Name="FocusContainer"
                                 Spacing="12"
                                 Padding="18,28,18,0"
                                 VerticalOptions="Start">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <Label Text="CRIMSON NEXUS"
                                   TextColor="{StaticResource CrimsonTextPrimary}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.1" />
                            <Label Text="AEROSPACE ASSISTANT // QUANTUMZ"
                                   Style="{StaticResource CyberLabelMuted}"
                                   FontSize="10"
                                   CharacterSpacing="1.2" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                Style="{StaticResource StatusPill}"
                                VerticalOptions="Center">
                            <Label Text="ONLINE"
                                   TextColor="{StaticResource CrimsonSuccess}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.2" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="DETAILS"
                                Command="{Binding ToggleDetailCommand}"
                                Style="{StaticResource CompactGhostButton}" />
                        <Button Grid.Column="1"
                                Text="MEMORY"
                                Command="{Binding ToggleMemoryCommand}"
                                Style="{StaticResource CompactGhostButton}" />
                        <Button Grid.Column="2"
                                Text="CONFIG"
                                Command="{Binding ToggleConfigCommand}"
                                Style="{StaticResource CompactGhostButton}" />
                    </Grid>
                </VerticalStackLayout>

                <Border Style="{StaticResource HudPanel}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{Binding StatusColor, Converter={StaticResource HexToColorConverter}}"
                                    WidthRequest="12"
                                    HeightRequest="12"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource CrimsonPrimaryAccent}"
                                            Offset="0,0"
                                            Radius="12"
                                            Opacity="0.9" />
                                </Border.Shadow>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="TACTICAL ASSISTANT CORE"
                                       Style="{StaticResource CyberLabelSection}"
                                       Margin="0"
                                       FontSize="12" />
                                <Label Text="Voice, memory, routing, and response systems are staged for command execution."
                                       Style="{StaticResource CyberLabelMuted}"
                                       FontSize="11"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Border Grid.Column="2"
                                    Style="{StaticResource StatusPill}"
                                    VerticalOptions="Center">
                                <Label Text="{Binding AiStatusText}"
                                       TextColor="{Binding StatusColor, Converter={StaticResource HexToColorConverter}}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       CharacterSpacing="1.1" />
                            </Border>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Progress="{Binding AudioLevel}"
                                     ProgressColor="{StaticResource CrimsonPrimaryAccent}"
                                     BackgroundColor="{StaticResource CrimsonSurfaceElevated}"
                                     HeightRequest="4" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource NeonFrame}"
                        MinimumHeightRequest="248">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                        <Grid Grid.Row="0" HeightRequest="146">
                            <Border x:Name="AssistantRing"
                                    WidthRequest="146"
                                    HeightRequest="146"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Stroke="{Binding StatusColor, Converter={StaticResource HexToColorConverter}}"
                                    StrokeThickness="2"
                                    BackgroundColor="{StaticResource CrimsonGlassInset}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="73" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource CrimsonPrimaryAccent}"
                                            Offset="0,0"
                                            Radius="34"
                                            Opacity="0.58" />
                                </Border.Shadow>

                                <Grid>
                                    <Ellipse WidthRequest="124"
                                             HeightRequest="124"
                                             Stroke="{StaticResource CrimsonGlassBorder}"
                                             StrokeThickness="1"
                                             Fill="Transparent"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center" />
                                    <Ellipse WidthRequest="92"
                                             HeightRequest="92"
                                             Stroke="{StaticResource CrimsonSecondaryAccent}"
                                             StrokeThickness="1"
                                             Opacity="0.42"
                                             Fill="Transparent"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center" />
                                    <Border x:Name="AssistantOrb"
                                            WidthRequest="66"
                                            HeightRequest="66"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            BackgroundColor="{Binding OrbColor}"
                                            Opacity="{Binding OrbOpacity}"
                                            Stroke="{StaticResource CrimsonTextPrimary}"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="33" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource CrimsonPrimaryAccent}"
                                                    Offset="0,0"
                                                    Radius="26"
                                                    Opacity="0.8" />
                                        </Border.Shadow>
                                    </Border>

                                    <Image Source="{Binding AssistantImageSource}"
                                           Aspect="AspectFit"
                                           WidthRequest="104"
                                           HeightRequest="104"
                                           Opacity="0.38"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />

                                    <Label Text="VAD"
                                           TextColor="{StaticResource CrimsonTextPrimary}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           CharacterSpacing="2"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="3">
                            <Label Text="{Binding StatusText}"
                                   Style="{StaticResource CyberLabelTitle}"
                                   FontSize="16"
                                   HorizontalOptions="Center" />
                            <Label Text="VOICE ACTIVITY DETECTION MATRIX"
                                   Style="{StaticResource HudMetricLabel}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Row="2"
                                               HeightRequest="34"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="7">
                            <BoxView x:Name="WaveBar1" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonPrimaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar2" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonSecondaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar3" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonPrimaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar4" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonSecondaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar5" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonTextPrimary}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar6" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonTextPrimary}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar7" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonSecondaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar8" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonPrimaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar9" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonSecondaryAccent}" AnchorY="0.5" />
                            <BoxView x:Name="WaveBar10" WidthRequest="5" HeightRequest="26" CornerRadius="3" BackgroundColor="{StaticResource CrimsonPrimaryAccent}" AnchorY="0.5" />
                        </HorizontalStackLayout>

                        <Border Grid.Row="3" Style="{StaticResource StatusPill}" HorizontalOptions="Center">
                            <Label Text="{Binding TranscriptionStatusText}"
                                   TextColor="{StaticResource CrimsonSuccess}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.4" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource HudPanel}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="LIVE TRANSCRIPT"
                               Style="{StaticResource CyberLabelSection}"
                               Margin="0"
                               FontSize="12" />
                        <Label Text="{Binding StreamingTranscriptDisplay}"
                               TextColor="{StaticResource CrimsonTextPrimary}"
                               FontSize="14"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Grid x:Name="PanelOverlay"
                  Padding="14,24,14,16"
                  Opacity="0"
                  InputTransparent="True">
                <Border Style="{StaticResource NeonFrame}"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="‹"
                                    Command="{Binding ClosePanelCommand}"
                                    Style="{StaticResource GhostButton}"
                                    WidthRequest="46"
                                    HeightRequest="42"
                                    FontSize="22"
                                    Padding="0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding PanelTitle}" Style="{StaticResource CyberLabelTitle}" FontSize="18" />
                                <Label Text="{Binding PanelSubtitle}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="CLOSE"
                                    Command="{Binding ClosePanelCommand}"
                                    Style="{StaticResource CompactGhostButton}"
                                    WidthRequest="84"
                                    HeightRequest="42" />
                        </Grid>

            <ScrollView x:Name="DetailPanel" Grid.Row="1" TranslationY="80" Opacity="0" InputTransparent="True">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <Border Grid.Row="0" Style="{StaticResource HudPanel}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="SERVICE HEALTH" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                    <Label Text="{Binding ServiceHealthSummaryText}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="TEST" Command="{Binding RefreshServiceHealthCommand}" Style="{StaticResource CompactGhostButton}" WidthRequest="82" />
                            </Grid>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding ServiceHealthItems}" Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" WidthRequest="9" HeightRequest="9" CornerRadius="5" BackgroundColor="{Binding AccentColor, Converter={StaticResource HexToColorConverter}}" VerticalOptions="Center">
                                                <BoxView.Triggers>
                                                    <DataTrigger TargetType="BoxView" Binding="{Binding IsPulsing}" Value="True">
                                                        <Setter Property="Opacity" Value="0.56" />
                                                    </DataTrigger>
                                                </BoxView.Triggers>
                                            </BoxView>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                <Label Text="{Binding Label}" Style="{StaticResource HudMetricLabel}" />
                                                <Label Text="{Binding Value}" Style="{StaticResource HudMetricValue}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource HudPanel}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="REAL-TIME SPEECH TRANSCRIPT" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                <Label Grid.Column="1" Text="STREAMING" TextColor="{StaticResource CrimsonSuccess}" FontSize="10" FontAttributes="Bold" CharacterSpacing="1.2" />
                            </Grid>
                            <Label Text="{Binding StreamingTranscriptDisplay}" TextColor="{StaticResource CrimsonTextPrimary}" FontSize="17" FontAttributes="Bold" LineBreakMode="WordWrap" MinimumHeightRequest="72" />
                            <Label Text="{Binding LastTranscription}" Style="{StaticResource CyberLabelMuted}" FontSize="12" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="14">
                        <Border Grid.Column="0" Style="{StaticResource HudPanel}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="MODEL STATUS" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                <Label Text="{Binding ActiveModelName}" Style="{StaticResource CyberLabelTitle}" FontSize="15" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ModelEndpointText}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ModelStatusItems}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="9">
                                                <BoxView Grid.Column="0" WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="{Binding AccentColor, Converter={StaticResource HexToColorConverter}}" VerticalOptions="Center" />
                                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                    <Label Text="{Binding Label}" Style="{StaticResource HudMetricLabel}" />
                                                    <Label Text="{Binding Value}" Style="{StaticResource HudMetricValue}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource HudPanel}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="SERVER / GPU" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                <Label Text="{Binding ServerHealthText}" Style="{StaticResource CyberLabelTitle}" FontSize="15" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding GpuStatusText}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ServerTelemetryItems}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="9">
                                                <BoxView Grid.Column="0" WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="{Binding AccentColor, Converter={StaticResource HexToColorConverter}}" VerticalOptions="Center" />
                                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                    <Label Text="{Binding Label}" Style="{StaticResource HudMetricLabel}" />
                                                    <Label Text="{Binding Value}" Style="{StaticResource HudMetricValue}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Style="{StaticResource HudPanel}" IsVisible="{Binding LastResponse, Converter={StaticResource StringNotEmptyConverter}}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ASSISTANT RESPONSE BUFFER" Style="{StaticResource CyberLabelSection}" Margin="0" />
                            <Label Text="{Binding LastResponse}" TextColor="{StaticResource CrimsonTextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>

            <ScrollView x:Name="MemoryPanel" Grid.Row="1" TranslationY="80" Opacity="0" InputTransparent="True">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                    <Border Grid.Row="0" Style="{StaticResource NeonFrame}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="MEMORY VAULT" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                    <Label Text="Local summaries, search state, and Obsidian vault routing." Style="{StaticResource CyberLabelMuted}" FontSize="12" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" Style="{StaticResource StatusPill}" VerticalOptions="Start">
                                    <Label Text="{Binding MemorySummaryCountText}" TextColor="{StaticResource CrimsonSuccess}" FontSize="10" FontAttributes="Bold" CharacterSpacing="1.1" />
                                </Border>
                            </Grid>
                            <Label Text="{Binding MemoryVaultPathText}" TextColor="{StaticResource CrimsonTextPrimary}" FontSize="13" LineBreakMode="TailTruncation" />
                            <Button Text="OPEN MEMORY VAULT" Command="{Binding NavigateToMemoryCommand}" Style="{StaticResource GhostButton}" HeightRequest="46" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource HudPanel}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="MEMORY TELEMETRY" Style="{StaticResource CyberLabelSection}" Margin="0" />
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding MemoryStatusItems}" Spacing="9">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="9">
                                            <BoxView Grid.Column="0" WidthRequest="8" HeightRequest="8" CornerRadius="4" BackgroundColor="{Binding AccentColor, Converter={StaticResource HexToColorConverter}}" VerticalOptions="Center" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                <Label Text="{Binding Label}" Style="{StaticResource HudMetricLabel}" />
                                                <Label Text="{Binding Value}" Style="{StaticResource HudMetricValue}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource HudPanel}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="LAST MEMORY EVENT" Style="{StaticResource CyberLabelSection}" Margin="0" />
                            <Label Text="{Binding LastMemorySummaryText}" TextColor="{StaticResource CrimsonTextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>

            <ScrollView x:Name="ConfigPanel" Grid.Row="1" TranslationY="80" Opacity="0" InputTransparent="True">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                    <Border Grid.Row="0" Style="{StaticResource NeonFrame}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="SYSTEM CONFIG" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                    <Label Text="Provider routing, model selection, audio route, and MCP fabric." Style="{StaticResource CyberLabelMuted}" FontSize="12" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" Style="{StaticResource StatusPill}" VerticalOptions="Start">
                                    <Label Text="ROUTED" TextColor="{StaticResource CrimsonSuccess}" FontSize="10" FontAttributes="Bold" CharacterSpacing="1.1" />
                                </Border>
                            </Grid>
                            <Button Text="OPEN FULL CONFIG" Command="{Binding NavigateToSettingsCommand}" Style="{StaticResource GhostButton}" HeightRequest="46" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">
                        <Border Grid.Column="0" Style="{StaticResource HudPanel}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="MODEL ROUTE" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                <Label Text="{Binding ActiveModelName}" Style="{StaticResource CyberLabelTitle}" FontSize="15" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ModelEndpointText}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource HudPanel}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="SYSTEM ROUTE" Style="{StaticResource CyberLabelSection}" Margin="0" />
                                <Label Text="{Binding ServerHealthText}" Style="{StaticResource CyberLabelTitle}" FontSize="15" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding GpuStatusText}" Style="{StaticResource CyberLabelMuted}" FontSize="11" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource HudPanel}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ACTIVE VOICE ROUTE" Style="{StaticResource CyberLabelSection}" Margin="0" />
                            <Label Text="{Binding ConfigVoiceRouteText}" TextColor="{StaticResource CrimsonTextPrimary}" FontSize="13" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom action bar removed to prevent content obscuration.
             Essential controls (Listening toggle, Debug) moved to top header or panels if needed. -->
    </Grid>
</ContentPage>
