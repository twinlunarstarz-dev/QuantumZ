<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:QuantumZ.UI.Converters"
             x:Class="QuantumZ.UI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:HexToColorConverter x:Key="HexToColorConverter" />
            <conv:BoolToListenTextConverter x:Key="BoolToListenTextConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
